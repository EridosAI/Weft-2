# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/

# Virtual environments
.venv/
venv/
# (top-level `env/` was historically ignored; removed to allow src/env/ — the
#  phase-2/3 explorer wrapper package — into the tree. Re-add as /env/ at the
#  repo root if a top-level venv named env/ is ever created.)

# Env snapshot from pip freeze (not part of pinned reqs).
.env_snapshot.txt

# Tensorboard runs inside results/
results/**/tb/

# Checkpoints and large artifacts
checkpoints/
*.pt
*.pth
*.ckpt

# Logs
logs/*.log
logs/*.pid

# IDE / editor
.vscode/
.idea/
.claude/
*.swp
.DS_Store

# OS
Thumbs.db

# Local-only state
*.local
.env

# Results — keep .json and .md, ignore raw dumps
results/**/*.npy
results/**/*.npz

# Data dir — bulk artifacts (rendered frames, aux training outputs, encoder cache).
# Keep small reference files via explicit !pattern overrides if/when added.
data/
